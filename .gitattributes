# Normalize all text files to LF inside the repo so the same code checks out
# identically on Windows (your machine), Linux CI, and the Linux Docker image.
# Without this, CRLF line endings can break shell scripts and Docker builds.
* text=auto eol=lf

# Windows-only script files keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary (never touch line endings / never diff as text).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
