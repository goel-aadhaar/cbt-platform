# ─────────────────────────────────────────────────────────────
# DRSK CBT API — environment variables template.
# Copy to `.env` (gitignored) and fill in real values:
#     Copy-Item .env.example .env
# Validated at startup by src/config/env.schema.ts — the app refuses to
# boot if anything here is missing or invalid.
# ─────────────────────────────────────────────────────────────

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Neon / PostgreSQL) ---
# Use Neon's DIRECT connection (pooling disabled) — required for migrations.
# Moving to AWS RDS later changes only this line.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
