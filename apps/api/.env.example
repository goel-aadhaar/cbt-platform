# ─────────────────────────────────────────────────────────────
# DRSK CBT API — environment variables
#
# Copy this file to `.env` (gitignored) and fill in real values:
#     Copy-Item .env.example .env
#
# The app validates these at startup (src/config/env.schema.ts) and
# refuses to boot if anything is missing or invalid.
# ─────────────────────────────────────────────────────────────

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (added in Phase 4) ---
# DATABASE_URL=postgresql://drsk:drsk@localhost:5432/drsk_cbt?schema=public
