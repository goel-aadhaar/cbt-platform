# ─────────────────────────────────────────────────────────────
# DRSK CBT API — environment variables template.
# Copy to `.env` (gitignored) and fill in real values:
#     Copy-Item .env.example .env
# Validated at startup by src/config/env.schema.ts — the app refuses to
# boot if anything here is missing or invalid.
# ─────────────────────────────────────────────────────────────

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Neon / PostgreSQL) ---
# Use Neon's DIRECT connection (pooling disabled) — required for migrations.
# Moving to AWS RDS later changes only this line.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# --- Logging ---
# One of: fatal error warn info debug trace silent
# Default: debug in development, info in production.
# LOG_LEVEL=debug

# --- Security ---
# Comma-separated allowed CORS origins (e.g. https://app.example.com,https://admin.example.com).
# Empty in dev = allow all; empty in production = block cross-origin requests.
# CORS_ORIGINS=
# Global rate limit per IP: THROTTLE_LIMIT requests per THROTTLE_TTL_MS window.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
