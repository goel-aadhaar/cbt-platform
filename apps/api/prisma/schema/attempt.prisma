enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

/// Proctoring / anti-malpractice signals reported by the exam client (§2.2).
enum ProctoringEventType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  FOCUS_LOSS
  COPY
  PASTE
  OTHER
}

/// NTA-style question-palette states (§2.2).
enum ResponseStatus {
  NOT_VISITED
  NOT_ANSWERED
  ANSWERED
  MARKED
  ANSWERED_MARKED
}

/// A student's attempt at an exam (§2.2). One per student per exam. The server
/// owns the clock: `expiresAt` is computed at start (min of start+duration and
/// the exam window) so the timer is refresh/reconnection-safe and auto-submits.
model Attempt {
  id          String        @id @default(uuid()) @db.Uuid
  instituteId String        @map("institute_id") @db.Uuid
  examId      String        @map("exam_id") @db.Uuid
  studentId   String        @map("student_id") @db.Uuid
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now()) @map("started_at")
  expiresAt   DateTime      @map("expires_at")
  submittedAt DateTime?     @map("submitted_at")
  /// Proctoring (§2.2): running count of reported violations; `flagged` is set
  /// when a violation-threshold auto-submit terminates the attempt.
  violationCount Int        @default(0) @map("violation_count")
  flagged        Boolean    @default(false)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  institute        Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  exam             Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  student          Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  responses        Response[]
  result           Result?
  proctoringEvents ProctoringEvent[]
  manualScores     ManualScore[]
  sectionTimes     AttemptSectionTime[]

  @@unique([examId, studentId])
  @@index([instituteId])
  @@index([studentId])
  @@map("attempts")
}

/// A student's response to one question within an attempt. Auto-saved.
model Response {
  id          String         @id @default(uuid()) @db.Uuid
  attemptId   String         @map("attempt_id") @db.Uuid
  questionId  String         @map("question_id") @db.Uuid
  instituteId String         @map("institute_id") @db.Uuid
  answer      Json?
  status      ResponseStatus @default(NOT_VISITED)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  attempt   Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([instituteId])
  @@map("responses")
}

/// A proctoring / anti-malpractice event reported by the exam client during an
/// attempt (§2.2) — e.g. the candidate switched tabs or left full screen.
model ProctoringEvent {
  id          String              @id @default(uuid()) @db.Uuid
  attemptId   String              @map("attempt_id") @db.Uuid
  instituteId String              @map("institute_id") @db.Uuid
  type        ProctoringEventType
  detail      String?
  createdAt   DateTime            @default(now()) @map("created_at")

  attempt   Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([instituteId])
  @@map("proctoring_events")
}

/// Time a candidate spent in each exam section (§2.8 — "time spent per section"
/// in the permanent historical record). The exam client reports elapsed deltas
/// periodically and the server accumulates them; the Result engine folds the
/// totals into each result's per-section breakdown.
model AttemptSectionTime {
  id          String   @id @default(uuid()) @db.Uuid
  attemptId   String   @map("attempt_id") @db.Uuid
  sectionId   String   @map("section_id") @db.Uuid
  instituteId String   @map("institute_id") @db.Uuid
  seconds     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attempt   Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([attemptId, sectionId])
  @@index([attemptId])
  @@index([instituteId])
  @@map("attempt_section_times")
}

/// Admin-assigned marks for a question set to MANUAL evaluation (§2.5), scored
/// per candidate attempt. The Result engine applies these instead of the answer
/// key when the exam question's scoring is MANUAL.
model ManualScore {
  id          String   @id @default(uuid()) @db.Uuid
  examId      String   @map("exam_id") @db.Uuid
  attemptId   String   @map("attempt_id") @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  instituteId String   @map("institute_id") @db.Uuid
  marks       Float
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attempt   Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([examId])
  @@index([instituteId])
  @@map("manual_scores")
}
