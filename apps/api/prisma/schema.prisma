// DRSK CBT — Prisma schema.
// The datasource connection URL is configured in prisma.config.ts (Prisma 7
// convention), sourced from DATABASE_URL. Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  // Generated into src/ so Nest's tsc build keeps a clean dist/ layout.
  // This folder is gitignored and regenerated via `prisma generate`.
  output       = "../src/generated/prisma"
  // NestJS runs on CommonJS. The default ESM output breaks at runtime with
  // "exports is not defined in ES module scope", so emit a CJS client.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

/// Root tenant of the platform (contract §2.1).
///
/// Every tenant-owned record (programs, batches, students, questions, exams,
/// results, …) will carry `institute_id` referencing this table and be scoped
/// to the requesting institute, so no institute can read another's data.
model Institute {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  /// URL-safe unique identifier for the tenant (e.g. used in login/routing).
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("institutes")
}
