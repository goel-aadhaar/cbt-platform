# Keeps whitespace/encoding consistent across every editor (VS Code, JetBrains, etc.)
# so diffs stay clean regardless of who edits a file. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown: trailing whitespace can be meaningful (hard line breaks).
[*.md]
trim_trailing_whitespace = false
