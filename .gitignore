# ---- Dependencies ----
node_modules/
.pnpm-store/

# ---- Build output ----
dist/
build/
*.tsbuildinfo

# ---- Test / coverage ----
coverage/
.nyc_output/
# API-suite scratch: the booted app's log (contains invitation tokens) and
# load-test reports. Never commit.
**/test/.tmp/

# ---- Confidential documents (NEVER commit) ----
# The signed service agreement carries both parties' names, home addresses and
# commercial terms. Keep contracts out of the repository entirely.
*.docx
*.doc
*.pdf

# ---- Environment & secrets (NEVER commit real values) ----
.env
.env.*
!.env.example
!.env.*.example

# ---- Logs ----
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ---- Task-runner / tooling caches ----
.turbo/
.cache/
.eslintcache

# ---- Prisma ----
# Generated client (regenerated via `prisma generate`) — never commit it.
generated/
*.sqlite
*.sqlite-journal

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
*.iml

.vscode/